{
	"name": "frontend-app",
	"version": "1.0.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "infisical run --env=dev --path=/app bun run vike dev",
		"build": "STAGE=staging infisical run --env=staging --path=/app -- bun run vike build",
		"build:prod": "STAGE=prod infisical run --env=prod --path=/app -- bun run vike build",
		"start": "infisical run --env=staging --path=/app -- bun run ./dist/server/index.mjs",
		"----------------": "",
		"lint": "bunx biome lint",
		"type-check": "bun scripts/fix-sprite.ts && tsc --build",
		"circular-check": "bunx dpdm --no-warning ./renderer/+onCreatePageContext.server.ts",
		"------------------": "",
		"build:image:prod": "infisical run --env=common --path=/root --make build",
		"build:image:tag": "infisical run --env=common --path=/root --make tag",
		"build:image:push": "infisical run --env=common --path=/root --make push",
		"--------------------": "",
		"release:prod": "infisical run --env=common --path=/root -- make all STAGE=prod NAME=frontend-main",
		"release:staging": "infisical run --env=common --path=/root -- make all STAGE=staging NAME=frontend-main",
		"machine-translate": "inlang machine translate --project project.inlang",
		"types:gen:openapi": "bun run openapi-typescript --redocly=./redocly.yml"
	},
	"sideEffects": [
		"**/*.css"
	],
	"dependencies": {
		"@ark-ui/react": "5.36.2",
		"@better-captcha/react": "0.7.0",
		"@bprogress/core": "1.3.4",
		"@fingerprintjs/fingerprintjs": "5.2.0",
		"@inlang/paraglide-js": "2.18.0",
		"@monaco-editor/react": "4.7.0",
		"@number-flow/react": "0.6.0",
		"@reatom/framework": "3.4.68",
		"@reatom/npm-react": "3.10.6",
		"@reatom/persist": "3.4.3",
		"@reatom/persist-web-storage": "3.4.6",
		"@reatom/undo": "3.4.2",
		"@reatom/url": "3.9.0",
		"@reatom/web": "3.6.0",
		"@repo/ui": "workspace:*",
		"@scure/bip39": "2.0.1",
		"@sinclair/typebox": "0.34.49",
		"@tabler/icons-react": "3.34.0",
		"@tanstack/react-table": "8.21.3",
		"@tiptap/extension-image": "3.10.5",
		"@tiptap/extension-table": "3.10.5",
		"@tiptap/extension-text-style": "3.10.5",
		"@tiptap/extensions": "3.10.5",
		"@tiptap/html": "3.10.5",
		"@tiptap/react": "3.10.5",
		"@tiptap/starter-kit": "3.10.5",
		"@tiptap/static-renderer": "3.10.5",
		"@universal-middleware/compress": "0.2.35",
		"@vikejs/elysia": "0.2.0",
		"@web-kits/audio": "0.1.0",
		"@yudiel/react-qr-scanner": "2.5.1",
		"clsx": "2.1.1",
		"dayjs": "1.11.11",
		"elysia": "1.4.28",
		"ky": "2.0.2",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-error-boundary": "6.0.0",
		"react-intersection-observer": "10.0.0",
		"react-skinview3d": "7.0.0",
		"skinview3d": "3.4.1",
		"sonner": "2.0.7",
		"tailwind-merge": "3.5.0",
		"tailwind-variants": "3.1.1",
		"vaul": "1.1.2",
		"vike": "0.4.258",
		"vike-react": "0.6.21",
		"zod": "4.2.1"
	},
	"devDependencies": {
		"@inlang/cli": "3.0.0",
		"@inlang/paraglide-js": "2.18.0",
		"@neodx/svg": "0.8.0",
		"@repo/config-biome": "workspace:*",
		"@repo/config-typescript": "workspace:*",
		"@tailwindcss/vite": "4.1.12",
		"@tweakpane/core": "2.0.5",
		"@types/react": "19.1.8",
		"@types/react-dom": "19.1.6",
		"@vitejs/plugin-react": "5.0.2",
		"consola": "3.4.2",
		"rollup-plugin-visualizer": "7.0.1",
		"tailwind-scrollbar": "4.0.2",
		"tailwindcss": "4.1.8",
		"openapi-typescript": "7.13.0",
		"tw-animate-css": "1.3.4",
		"tweakpane": "4.0.5",
		"typescript": "~5.8.3",
		"vite": "7.2.7",
		"vite-tsconfig-paths": "5.1.4"
	}
}
