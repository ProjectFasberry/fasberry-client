{
	"name": "landing",
	"version": "1.0.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"start": "infisical run --env=prod --path=/landing -- node ./dist/server/index.mjs --port 3005",
		"dev": "infisical run --env=dev --path=/landing -- vike dev --port 3005 --host",
		"build": "infisical run --env=prod --path=/landing -- vike build",
		"preview": "vike preview --port 3005 --host",
		"--------------": "",
		"lint": "bunx biome lint",
		"type-check": "tsc --build",
		"circular-check": "bunx dpdm --no-warning ./renderer/+Layout.tsx",
		"------------------": "",
		"deploy": "cross-env STAGE=prod bun run build && wrangler deploy"
	},
	"sideEffects": [
		"**/*.css"
	],
	"dependencies": {
		"@ark-ui/solid": "5.36.2",
		"@bprogress/core": "1.3.4",
		"@corvu/drawer": "0.2.4",
		"@reatom/framework": "3.4.68",
		"@reatom/npm-solid-js": "3.6.2",
		"@reatom/persist": "3.4.3",
		"@tiptap/extension-image": "3.10.5",
		"@tiptap/extension-table": "3.10.5",
		"@tiptap/extension-text-style": "3.10.5",
		"@tiptap/extensions": "3.10.5",
		"@tiptap/html": "3.10.5",
		"@tiptap/starter-kit": "3.10.5",
		"@tiptap/static-renderer": "3.10.5",
		"clsx": "2.1.1",
		"dayjs": "1.11.11",
		"ky": "1.14.0",
		"solid-js": "1.9.13",
		"solid-sonner": "0.3.1",
		"tailwind-merge": "3.6.0",
		"tailwind-variants": "3.1.1",
		"vike": "0.4.259",
		"vike-solid": "0.8.2",
		"zod": "4.1.11"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "1.38.0",
		"@neodx/svg": "0.8.0",
		"@repo/config-biome": "workspace:*",
		"@repo/config-typescript": "workspace:*",
		"@repo/shared": "workspace:*",
		"@tailwindcss/vite": "4.3.0",
		"rollup-plugin-visualizer": "7.0.1",
		"tailwind-scrollbar": "4.0.2",
		"tailwindcss": "4.1.8",
		"tw-animate-css": "1.3.4",
		"typescript": "5.8.3",
		"vite": "8.0.14",
		"wrangler": "4.94.0"
	}
}
